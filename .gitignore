!sync-drops/otter-transcripts/.gitkeep
sync-drops/claude-research/*
!sync-drops/claude-research/.gitkeep
sync-drops/misc/*
!sync-drops/misc/.gitkeep

# Python
__pycache__/
*.pyc

# OS
.DS_Store
